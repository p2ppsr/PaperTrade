# PaperTrade local development configuration.
# Copy this file to .env and replace values for your machine.

NODE_ENV=development
HTTP_PORT=3001
ROUTING_PREFIX=/api
HOSTING_DOMAIN=http://localhost:5173
DATA_DIR=./data
JSON_BODY_LIMIT=80mb

SQL_CLIENT=mysql2
SQL_DATABASE_HOST=127.0.0.1
SQL_DATABASE_PORT=3306
SQL_DATABASE_USER=papertrade
SQL_DATABASE_PASSWORD=papertrade
SQL_DATABASE_DB_NAME=papertrade

# mainnet maps to the BSV main chain; testnet maps wallet-toolbox to test.
BSV_NETWORK=mainnet
WALLET_STORAGE_URL=https://storage.babbage.systems

# Optional. If omitted, PaperTrade creates or reuses DATA_DIR/server-private-key.
# SERVER_PRIVATE_KEY=
# SERVER_PRIVATE_KEY_PATH=./data/server-private-key

# Optional server-side telemetry target.
USERCOM_SIGNAL_ENDPOINT=https://usercom.babbage.systems/signal

# Optional wallet bootstrap tuning.
WALLET_BOOTSTRAP_RETRY_COUNT=8
WALLET_BOOTSTRAP_RETRY_DELAY_MS=2500

# Optional frontend wallet override for local debugging.
# VITE_WALLET_ORIGINATOR=localhost
# VITE_WALLET_SUBSTRATE=json-api
# VITE_APP_VERSION=local
