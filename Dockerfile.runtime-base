FROM node:22-bookworm-slim

LABEL org.opencontainers.image.title="PaperTrade runtime base"
LABEL org.opencontainers.image.description="Node.js plus PDF/docx/ePub conversion tools for PaperTrade"

ENV NODE_ENV=production

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    poppler-utils \
    libreoffice-writer \
    calibre \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app
